# ══════════════════════════════════════════════════════════════
#  NoteFlow 环境变量配置
#  复制为 .env 后填写 JWT_SECRET 即可启动
# ══════════════════════════════════════════════════════════════

# ── 必须修改（安全关键）────────────────────────────────────────
# JWT 密钥：至少 32 位随机字符串，生产环境务必修改
# 生成示例：openssl rand -hex 32
JWT_SECRET=please_change_this_to_a_random_64_char_secret_string_in_production

# ── 数据库（可选，不填则使用默认值）───────────────────────────
POSTGRES_USER=notes_user
POSTGRES_PASSWORD=notes_pass
POSTGRES_DB=notes_db

# ── 端口与跨域（可选）──────────────────────────────────────────
APP_PORT=3000
CORS_ORIGIN=*
